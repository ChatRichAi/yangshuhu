{
  "manifest_version": 3,
  "name": "养薯户 - 小红书自动养号",
  "version": "3.0.1",
  "description": "小红书自动养号工具，模拟真实用户行为完成浏览、点赞、收藏、评论等养号任务。",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "activeTab",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://xhslink.com/*",
    "http://localhost:*/*",
    "ws://localhost:*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
